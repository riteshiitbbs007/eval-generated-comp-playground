<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>62.0</apiVersion>
  <description>Responsive card grid component that displays cards in 4 columns on desktop, 2 columns on tablet, and 1 column on mobile. Follows SLDS 2 design system guidelines with full accessibility support.</description>
  <isExposed>true</isExposed>
  <targets>
    <target>lightning__AppPage</target>
    <target>lightning__RecordPage</target>
    <target>lightning__HomePage</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightning__AppPage,lightning__RecordPage,lightning__HomePage">
      <supportedFormFactors>
        <supportedFormFactor type="Small"/>
        <supportedFormFactor type="Medium"/>
        <supportedFormFactor type="Large"/>
      </supportedFormFactors>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>